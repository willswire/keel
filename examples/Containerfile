ARG PYTHON_VERSION=3.12

FROM python:${PYTHON_VERSION}-alpine AS build
WORKDIR /src
COPY src/ /src/
RUN python -m compileall -q /src

FROM python:${PYTHON_VERSION}-alpine

LABEL NAME=hello-world \
    org.opencontainers.image.title="Hello World" \
    org.opencontainers.image.description="Example app generated by keel"

WORKDIR /app

ENV APP_MESSAGE="Hello from Containerfile!" \
    APP_PORT=8080 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN addgroup -S app && adduser -S -D -u 10001 -G app appuser

COPY --from=build /src/ /app/

USER 10001

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 CMD ["python", "/app/server.py", "--healthcheck"]

ENTRYPOINT ["python", "/app/server.py"]
CMD ["--port", "8080"]
